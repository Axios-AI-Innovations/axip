{
  "instance": {
    "id": "data-extract",
    "name": "Data Extract",
    "version": "0.1.0"
  },

  "models": {
    "ollama": {
      "primary": "qwen3:14b"
    }
  },

  "extraction": {
    "fetch_timeout_ms": 15000,
    "max_page_chars": 40000,
    "max_output_tokens": 1024,
    "temperature": 0.1
  },

  "budget": {
    "warning_threshold_usd": 0,
    "hard_cap_usd": 0,
    "period": "monthly"
  },

  "axip": {
    "relay_url": "ws://127.0.0.1:4200",
    "agent_name": "data-extract",
    "capabilities": ["data_extraction"],
    "pricing": {
      "data_extraction": { "base_usd": 0.04 }
    },
    "bidding": {
      "auto_bid": true,
      "max_concurrent_tasks": 4,
      "default_eta_seconds": 20,
      "default_confidence": 0.85
    },
    "metadata": {
      "operator": "Axios AI Innovations",
      "mission_aligned": true,
      "node_type": "core",
      "runtime": "ollama/qwen3:14b"
    }
  }
}

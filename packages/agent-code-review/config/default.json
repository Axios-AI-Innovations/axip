{
  "instance": {
    "id": "code-review",
    "name": "Code Review",
    "version": "0.1.0"
  },

  "models": {
    "ollama": {
      "primary": "qwen3:14b"
    }
  },

  "code_review": {
    "max_input_chars": 32000,
    "max_output_tokens": 2048,
    "temperature": 0.2
  },

  "budget": {
    "warning_threshold_usd": 0,
    "hard_cap_usd": 0,
    "period": "monthly"
  },

  "axip": {
    "relay_url": "ws://127.0.0.1:4200",
    "agent_name": "code-review",
    "capabilities": ["code_review"],
    "pricing": {
      "code_review": { "base_usd": 0.05 }
    },
    "bidding": {
      "auto_bid": true,
      "max_concurrent_tasks": 3,
      "default_eta_seconds": 30,
      "default_confidence": 0.88
    },
    "metadata": {
      "operator": "Axios AI Innovations",
      "mission_aligned": true,
      "node_type": "core",
      "runtime": "ollama/qwen3:14b"
    }
  }
}
